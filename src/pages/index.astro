---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL;
const url = (path: string) => `${base.replace(/\/$/, '')}/${path.replace(/^\//, '')}`;
const bookDemo = 'https://outlook.office.com/book/Moyai1@moyai.com.au/';
const ctaAria = "Let's talk, book a call with Moyai (opens in a new tab)";

const valueProps = [
  {
    title: 'Verified data',
    body:
      'Moyai collects granular accessibility data down to door widths, rail positions, and floor surface types. Accurate, reliable, and verified by allied health professionals who know what guests with accessibility and sensory needs actually depend on.',
  },
  {
    title: 'Ready when your guests call',
    body:
      'Your reservations team gets instant access to verified accessibility information for every accessible room, so when a guest calls, you can answer with confidence and give them exactly what they need to book.',
  },
  {
    title: 'Built by allied health professionals',
    body:
      'Moyai was founded by a physiotherapist and exercise physiologist who assess properties using the same clinical precision they bring to patient care. When Moyai verifies something, your guests can trust it.',
  },
];

const reasons = [
  {
    title: 'Minimal disruption, maximum return',
    body:
      "Setup is straightforward and fits around your operations. Once your accessibility data is verified and loaded, your team can keep it current in house with Moyai's support. No ongoing disruption. Just a reservations team that answers accessibility enquiries with confidence.",
  },
  {
    title: 'Accessibility is more than a ramp at the front door',
    body:
      'Accessibility spans mobility, sensory, cognitive and communication needs. Most properties have more to offer than they realise and most are not communicating it.',
  },
  {
    title: 'Already have accessibility information on your website?',
    body:
      'Most properties do. But is it verified, consistent across every platform and specific enough for a guest to make a confident booking decision? Moyai ensures what you say matches what you have.',
  },
  {
    title: 'Too busy right now?',
    body:
      'We get it. That is why we have made the process as streamlined as possible. Once set up, Moyai reduces the time your team spends on accessibility enquiries, increases accessible room bookings and gives you clear visibility on return from your accessible inventory.',
  },
];

const steps = [
  {
    title: 'Book a 20 minute call',
    body: 'A quick conversation to explore whether Moyai is the right fit for your property.',
  },
  {
    title: 'We collect and verify your accessibility data',
    body:
      'Working with your team to gather and verify the information that matters to guests with accessibility and sensory needs.',
  },
  {
    title: 'Your property is ready',
    body:
      'Your reservations team answers every accessibility enquiry with confidence and your verified accessibility information is consistent across your website and OTA listings.',
  },
];

const partners = [
  { name: 'Queensland Tourism Industry Council', href: 'https://www.qtic.com.au/', src: url('images/partner-qti.png') },
  { name: 'Queensland Social Enterprise Council', href: 'https://www.qsec.org.au/', src: url('images/partner-qsec.png') },
  { name: 'People and Planet First', href: 'https://peopleandplanetfirst.org/', src: url('images/partner-ppf.jpg') },
];
---

<Layout>
  <!-- Hero -->
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <h1>Accessibility that grows your business</h1>
        <p class="hero-sub">Verified. Trusted by your guests. Ready when they enquire.</p>
        <a class="btn btn-primary" href={bookDemo} target="_blank" rel="noopener noreferrer" aria-label={ctaAria}>Let's talk</a>
      </div>
      <div class="hero-media">
        <img src={url('images/hero.png')} alt="Example of a Moyai accessibility report for a hotel room, showing verified details such as entry, flooring, and sensory information." width="1992" height="950" />
      </div>
    </div>
  </section>

  <!-- The problem / The reality / Our approach -->
  <section class="section">
    <div class="container">
      <div class="trio">
        <article>
          <h2>The problem</h2>
          <p class="text-muted">
            Accessible rooms exist. The information guests need to book with confidence does
            not. Information becomes inconsistent across platforms, goes out of date, and no
            longer reflects what a property actually offers. Guests call. Staff guess. Bookings
            go elsewhere.
          </p>
        </article>
        <article>
          <h2>The reality</h2>
          <p class="text-muted">
            Travellers with accessibility needs took 70.5 million trips in Australia in 2024
            and spent $29.2 billion, 17% of total visitor spend. Travelling in groups of 3.2
            on average, every accessible room booking is effectively a group booking. Most
            accommodation providers are not capitalising on that opportunity.
          </p>
        </article>
        <article>
          <h2>Our approach</h2>
          <p class="text-muted">
            Moyai verifies the accessibility of your property and powers a booking assistant
            for your reservations team. When a guest asks about roll-in showers, grab rail
            placement, or wheelchair clearance, your staff have a verified answer ready. No
            guessing. No running to the room. No lost booking.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- Why Moyai -->
  <section class="section why" aria-labelledby="why-heading">
    <div class="container">
      <h2 id="why-heading" class="section-title">Why Moyai</h2>
      <div class="why-box">
        <ul class="reason-list">
          {reasons.map((item) => (
            <li>
              <h3 class="reason-headline">{item.title}</h3>
              <p class="reason-body">{item.body}</p>
            </li>
          ))}
        </ul>
      </div>
      <div class="why-cta">
        <a class="btn btn-primary" href={bookDemo} target="_blank" rel="noopener noreferrer" aria-label={ctaAria}>Let's talk</a>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="section how" aria-labelledby="how-heading">
    <div class="container">
      <h2 id="how-heading" class="section-title">How it works</h2>
      <ol class="steps">
        {steps.map((step) => (
          <li class="step">
            <h3>{step.title}</h3>
            <p>{step.body}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- Be the hotel that gets it right banner -->
  <section class="section cta" aria-labelledby="cta-heading">
    <div class="container cta-inner">
      <h2 id="cta-heading">Be the hotel that gets it right.</h2>
      <p class="cta-body">
        When a guest with accessibility needs calls, your team has the answer. Every time.
      </p>
      <a class="btn btn-primary" href={bookDemo} target="_blank" rel="noopener noreferrer" aria-label={ctaAria}>Let's talk</a>
    </div>
  </section>

  <!-- Value propositions -->
  <section class="section" aria-labelledby="value-heading">
    <div class="container">
      <h2 id="value-heading" class="sr-only">Value propositions</h2>
      <div class="card-grid">
        {valueProps.map((item) => (
          <article class="card">
            <h3>{item.title}</h3>
            <p class="text-muted">{item.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonial -->
  <section class="section testimonial" aria-labelledby="testimonial-heading">
    <div class="container">
      <h2 id="testimonial-heading" class="section-title">What people are saying</h2>
      <figure>
        <blockquote>
          <p>
            When Moyai approached us, we were eager to have them audit Ardo's online
            presence, across our website and partner booking platforms like Booking.com.
            Moyai far exceeded our expectations with a comprehensive review of our digital
            listings, covering everything from hotel rooms to our restaurants and Rooftop Pool.
          </p>
          <p>
            They identified key accessibility information that had been previously overlooked
            and clearly explained the importance and benefits of addressing these gaps. Simple
            yet impactful fixes, such as adding alt text to images, were highlighted with
            practical recommendations. Importantly, Moyai also audited our team's knowledge of
            accessibility, helping us understand how staff awareness directly influences the
            guest experience. Their insights have empowered our team to better support guests
            of all abilities.
          </p>
          <p>
            Moyai's audit showcased their deep expertise in accessibility and provided
            invaluable guidance that will significantly enhance the experience we offer. Their
            contribution has been truly transformative.
          </p>
        </blockquote>
        <figcaption>Brent Clark, General Manager of Ardo, The Ville Resort, Casino</figcaption>
      </figure>
    </div>
  </section>

  <!-- Partners -->
  <section class="section partners" aria-labelledby="partners-heading">
    <div class="container">
      <h2 id="partners-heading" class="section-title">Partners</h2>
      <ul class="partner-logos">
        {partners.map((p) => (
          <li>
            <a href={p.href} target="_blank" rel="noopener noreferrer" aria-label={`Visit ${p.name} (opens in a new tab)`}>
              <img src={p.src} alt={`${p.name} logo`} loading="lazy" />
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
</Layout>

<style>
  /* Hero */
  .hero {
    padding-block: clamp(3rem, 7vw, 5.5rem);
    background:
      radial-gradient(1200px 500px at 80% -10%, hsl(var(--color-primary) / 0.16), transparent 60%),
      hsl(var(--color-secondary) / 0.4);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    align-items: center;
    gap: 3rem;
  }
  .hero-sub {
    font-size: clamp(1.1rem, 2vw, 1.4rem);
    color: hsl(var(--color-muted));
    max-width: 34ch;
    margin-bottom: 2rem;
  }
  .hero-media img {
    border-radius: var(--radius);
    box-shadow: 0 30px 60px hsl(var(--color-foreground) / 0.12);
  }

  /* The problem / The reality / Our approach */
  .trio {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    text-align: center;
  }
  .trio article { padding: 0 2rem; }
  .trio article + article { border-left: 1px solid hsl(var(--color-border)); }
  .trio h2 {
    font-size: 1.375rem;
    color: hsl(var(--color-primary-foreground));
    margin-bottom: 0.6rem;
  }

  /* Why Moyai */
  .why { background: hsl(var(--color-secondary) / 0.5); }
  /* Shadow box holding the four points */
  .why-box {
    max-width: 760px;
    margin: 2.5rem auto 0;
    background: #fff;
    border: 1px solid hsl(var(--color-border));
    border-radius: var(--radius);
    box-shadow: 0 20px 45px hsl(var(--color-foreground) / 0.1);
    padding: 0.5rem 2rem;
  }
  .reason-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .reason-list li {
    padding: 1.5rem 0;
  }
  .reason-list li + li {
    border-top: 1px solid hsl(var(--color-border));
  }
  /* Headline reads as a bold heading (real <h3>); body stays regular weight */
  .reason-headline {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.15rem;
    line-height: 1.25;
    color: hsl(var(--color-foreground));
    margin: 0 0 0.4rem;
  }
  .reason-body {
    font-family: var(--font-body);
    font-weight: 400;
    color: hsl(var(--color-foreground));
    margin: 0;
  }
  .why-cta {
    text-align: center;
    margin-top: 2.5rem;
  }

  /* How it works (ordered steps) */
  .steps {
    counter-reset: step;
    list-style: none;
    margin: 2.5rem 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .step {
    counter-increment: step;
    background: #fff;
    border: 1px solid hsl(var(--color-border));
    border-radius: var(--radius);
    padding: 1.75rem;
    box-shadow: 0 1px 2px hsl(var(--color-foreground) / 0.04);
  }
  .step::before {
    content: "Step " counter(step);
    display: block;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.95rem;
    color: #000;
    margin-bottom: 0.5rem;
  }
  .step h3 { margin: 0 0 0.4rem; }
  .step p { margin: 0; }

  /* Value cards */
  .card-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .card {
    background: #fff;
    border: 1px solid hsl(var(--color-border));
    border-radius: var(--radius);
    padding: 1.75rem;
    box-shadow: 0 1px 2px hsl(var(--color-foreground) / 0.04);
  }
  .card h3 { color: hsl(var(--color-primary-foreground)); }

  /* Be the hotel that gets it right banner */
  .cta { background: hsl(var(--color-primary) / 0.12); }
  .cta-inner { text-align: center; margin-inline: auto; max-width: 60ch; }
  .cta-inner h2 {
    font-size: clamp(1.6rem, 3vw, 2.25rem);
    margin-bottom: 1rem;
  }
  .cta-body {
    font-size: 1.125rem;
    color: #000;
    margin: 0 auto 1.75rem;
    max-width: 48ch;
  }

  /* Testimonial */
  .testimonial figure { margin: 1.5rem auto 0; max-width: 70ch; }
  .testimonial blockquote {
    margin: 0;
    font-size: 1.125rem;
    color: #000;
    border-left: 4px solid hsl(var(--color-primary));
    padding-left: 1.5rem;
  }
  .testimonial figcaption {
    margin-top: 1rem;
    font-family: var(--font-heading);
    font-weight: 600;
  }

  /* Partners */
  .partners { text-align: center; }
  .partner-logos {
    list-style: none;
    margin: 2rem 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 3.5rem;
  }
  .partner-logos a {
    display: inline-flex;
    border-radius: var(--radius);
    transition: transform 0.15s ease, opacity 0.15s ease;
  }
  .partner-logos a:hover,
  .partner-logos a:focus-visible {
    transform: translateY(-2px);
  }
  .partner-logos a:hover img,
  .partner-logos a:focus-visible img {
    opacity: 1;
    filter: none;
  }
  .partner-logos img {
    height: 150px;
    width: auto;
    object-fit: contain;
    filter: grayscale(0.15);
    opacity: 0.9;
  }

  @media (max-width: 880px) {
    .hero-grid { grid-template-columns: 1fr; }
    .hero-media { order: -1; }
    .trio { grid-template-columns: 1fr; }
    .trio article { padding: 1.25rem 0; }
    .trio article + article { border-left: none; border-top: 1px solid hsl(var(--color-border)); }
    .steps { grid-template-columns: 1fr; }
    .card-grid { grid-template-columns: 1fr; }
    .why-box { padding: 0.5rem 1.25rem; }
    .partner-logos { gap: 2.5rem; justify-content: center; }
    .partner-logos img { height: 110px; }
  }
</style>
