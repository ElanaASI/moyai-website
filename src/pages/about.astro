---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL;
const url = (path: string) => `${base.replace(/\/$/, '')}/${path.replace(/^\//, '')}`;

const storyImages = [
  {
    src: url('images/story-short-hair-smile.jpg'),
    alt: 'A lady with short hair and a warm smile facing the camera.',
    w: 931,
    h: 1071,
  },
  {
    src: url('images/story-couple-power-wheelchair.jpg'),
    alt: 'A man standing next to his wife who is a power drive wheelchair user.',
    w: 886,
    h: 1133,
  },
  {
    src: url('images/story-tina-races.jpg'),
    alt: 'Tina, a Moyai user, sitting on a white folding chair dressed up for the races.',
    w: 768,
    h: 1024,
  },
  {
    src: url('images/story-flowers-wheelchair.jpg'),
    alt: 'A lady sitting in a wheelchair with a warm smile and a large bunch of flowers on her lap.',
    w: 571,
    h: 1024,
  },
];

const stats = [
  { value: '5.5 million', label: 'Australians live with disability' },
  { value: '5.9 million', label: 'Australians have chronic health conditions' },
  { value: '44%', label: 'avoid outings due to accessibility barriers' },
  { value: '40%', label: 'depend on daily informal or family support' },
];

const values = [
  { title: 'Clarity', body: 'A profound understanding through insight.' },
  { title: 'Compassion', body: 'Act with care and consideration.' },
  { title: 'Evolution', body: 'Leading through curiosity and learning.' },
  { title: 'Amplifying', body: 'Make the unheard roar.' },
];

const pvm = [
  { label: 'Purpose', body: 'To ensure everyone can live a fulfilling life.' },
  { label: 'Vision', body: 'We see a world that works for all bodies, minds and needs.' },
  { label: 'Mission', body: 'We are the trusted source for accessibility tools, data and action.' },
];
---

<Layout
  title="About Moyai"
  description="Moyai was founded by physiotherapist Elana Fernandes to build a world that works for all bodies, minds and needs — grounded in empathy and shaped by lived experience."
>
  <!-- Intro -->
  <section class="section about-hero">
    <div class="container story-grid">
      <div class="story-copy">
        <h1>How the story began</h1>
        <p class="lead">
          Venues are rarely designed with people living with disability in mind. Too often,
          accessibility information is missing or unclear, leaving people guessing, stressing,
          or staying at home. For businesses, this means lost opportunities to welcome and
          retain valuable customers.
        </p>
        <p class="lead">
          Moyai was co-founded by physiotherapist Elana Fernandes, inspired by her brother who
          lives with a disability and by the clients she has cared for throughout her career.
          Seeing the barriers they face made the challenge personal and urgent.
        </p>
        <p class="lead">
          Step by step, Moyai is working towards a world that works for all bodies, minds and
          needs, grounded in empathy and shaped by lived experience.
        </p>
      </div>
      <div class="story-media">
        {storyImages.map((img) => (
          <img src={img.src} alt={img.alt} width={img.w} height={img.h} loading="lazy" />
        ))}
      </div>
    </div>
  </section>

  <!-- Problem / Reality / Solution -->
  <section class="section">
    <div class="container">
      <div class="trio">
        <article>
          <h2>The problem</h2>
          <p class="text-muted">
            Accessible rooms exist. The information guests need to book with confidence does
            not. Guests call. Staff guess. Bookings go elsewhere.
          </p>
        </article>
        <article>
          <h2>The reality</h2>
          <p class="text-muted">
            Travellers with accessibility needs took 70.5 million trips in Australia in 2024
            and spent $29.2 billion, 17% of total visitor spend. Travelling in groups of 3.2
            on average, every accessible room booking is effectively a group booking. Most
            accommodation providers are not capitalising on that opportunity.
          </p>
        </article>
        <article>
          <h2>Our approach</h2>
          <p class="text-muted">
            Moyai verifies the accessibility of your property and powers a booking assistant
            for your reservations team. When a guest asks about roll-in showers, grab rail
            placement, or wheelchair clearance, your staff have a verified answer ready. No
            guessing. No running to the room. No lost booking.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="section stats-section" aria-labelledby="stats-heading">
    <div class="container">
      <h2 id="stats-heading" class="sr-only">The scale of the opportunity</h2>
      <ul class="stat-grid">
        {stats.map((s) => (
          <li>
            <svg class="stat-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M9 21c0 .55.45 1 1 1h4c.55 0 1-.45 1-1v-1H9v1zm3-19C8.14 2 5 5.14 5 9c0 2.38 1.19 4.47 3 5.74V17c0 .55.45 1 1 1h6c.55 0 1-.45 1-1v-2.26c1.81-1.27 3-3.36 3-5.74 0-3.86-3.14-7-7-7z"/>
            </svg>
            <span class="stat-value">{s.value}</span>
            <span class="stat-label">{s.label}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Commitment banner -->
  <section class="commitment">
    <div class="container">
      <p class="goal">Moyai is committed to improving the accessibility and inclusion of 50,000 businesses by 2032.</p>
    </div>
  </section>

  <!-- Triple Impact Model -->
  <section class="section impact-section">
    <div class="container">
      <div class="impact-grid">
        <article class="card impact-lead">
          <h2>Bridging the gap</h2>
          <p class="text-muted">
            Moyai verifies that a property's accessibility information is accurate, so
            travellers with access needs can trust it and choose the places ready to welcome
            them, moving the whole industry toward more inclusive travel.
          </p>
        </article>
        <article class="card">
          <h3>Data for purpose</h3>
          <p class="text-muted">
            Moyai shows you where your access already works so you can promote it with
            confidence, and the simple adjustments that would unlock more bookings.
          </p>
        </article>
        <article class="card">
          <h3>Inclusive employment pathways</h3>
          <p class="text-muted">
            Built to include people living with disabilities in the work we do, creating real
            job opportunities and using lived experience to improve communities.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- Purpose / Vision / Mission -->
  <section class="section">
    <div class="container">
      <div class="pvm-grid">
        {pvm.map((item) => (
          <article class="pvm">
            <h3>{item.label}</h3>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Purpose statement banner -->
  <section class="purpose-section">
    <div class="container">
      <h2 class="section-title">Purpose statement</h2>
      <p class="reinvest">
        More than 50% of Moyai's profits are reinvested into creating meaningful employment
        pathways for people living with disabilities, enhancing our accessibility monitoring
        tools and building more inclusive communities.
      </p>
      <p class="reinvest">
        By continually improving our platform and tools, we empower businesses with the
        insights they need to make smarter, targeted accessibility investments, creating
        spaces where everyone can confidently participate and belong.
      </p>
    </div>
  </section>

  <!-- Values -->
  <section class="section values-section">
    <div class="container">
      <h2 class="section-title">Moyai company values</h2>
      <ul class="values-list">
        {values.map((v) => (
          <li class="value-item">
            <h3>{v.title}</h3>
            <p class="text-muted">{v.body}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>
</Layout>

<style>
  .narrow { max-width: 64ch; }
  .about-hero { background: hsl(var(--color-secondary) / 0.5); }
  .lead { font-size: 1.2rem; color: hsl(var(--color-foreground) / 0.85); }

  /* Story intro: copy beside a grid of photos */
  .story-grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: clamp(2rem, 4vw, 3.5rem);
    align-items: center;
  }
  .story-copy { max-width: 60ch; }
  .story-media {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .story-media img {
    display: block;
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    object-position: center top;
    border-radius: var(--radius);
    box-shadow: 0 12px 30px hsl(var(--color-foreground) / 0.12);
    filter: grayscale(1);
  }

  .trio {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    text-align: center;
  }
  .trio article { padding: 0 2rem; }
  .trio article + article { border-left: 1px solid hsl(var(--color-border)); }
  .trio h2 {
    font-size: 1.375rem;
    color: hsl(var(--color-primary-foreground));
    margin-bottom: 0.6rem;
  }

  .stats-section { background: hsl(var(--color-secondary) / 0.5); }
  .stat-grid {
    list-style: none;
    margin: 2rem 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }
  .stat-grid li {
    position: relative;
    background: #fff;
    border: 2px solid hsl(var(--color-primary));
    border-radius: var(--radius);
    padding: 1.75rem 1.5rem 1.5rem;
    text-align: center;
  }
  .stat-icon {
    position: absolute;
    top: 0.85rem;
    right: 0.85rem;
    width: 22px;
    height: 22px;
    color: hsl(var(--color-primary));
  }
  .stat-value {
    display: block;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.375rem;
    color: hsl(var(--color-foreground));
  }
  .stat-label { display: block; margin-top: 0.5rem; font-size: 0.95rem; color: hsl(var(--color-foreground)); }
  /* Full-width pink commitment banner */
  .commitment {
    background: hsl(var(--color-primary) / 0.45);
    padding-block: 2.75rem;
  }
  .commitment .goal {
    margin: 0 auto;
    max-width: 64ch;
    text-align: center;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 1.25rem;
    color: hsl(var(--color-foreground));
  }

  /* Triple Impact Model */
  .impact-section { background: hsl(var(--color-secondary) / 0.5); }
  .impact-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .impact-grid .card { text-align: center; }
  .impact-lead h2 {
    font-size: 1.375rem;
    color: hsl(var(--color-foreground));
    margin: 0 0 0.6rem;
  }

  .pvm-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .pvm {
    border-left: 4px solid hsl(var(--color-primary));
    padding-left: 1.25rem;
  }
  .purpose-section {
    border-top: 2px solid hsl(var(--color-primary));
    border-bottom: 2px solid hsl(var(--color-primary));
    padding-block: clamp(3rem, 6vw, 4.5rem);
  }
  .reinvest {
    max-width: 70ch;
    margin: 0 auto;
    text-align: center;
    font-size: 1.1rem;
  }
  .reinvest + .reinvest { margin-top: 1.25rem; }

  .values-section { background: hsl(var(--color-secondary) / 0.5); }
  .values-list {
    list-style: none;
    margin: 2rem auto 0;
    padding: 0;
    max-width: 52ch;
    text-align: center;
  }
  .value-item + .value-item { margin-top: 2rem; }
  .value-item h3 { margin-bottom: 0.4rem; }
  .card {
    background: #fff;
    border: 1px solid hsl(var(--color-border));
    border-radius: var(--radius);
    padding: 1.5rem;
  }

  @media (max-width: 880px) {
    .story-grid { grid-template-columns: 1fr; }
    .story-copy { max-width: none; }
    .trio, .pvm-grid { grid-template-columns: 1fr; }
    .trio article { padding: 1.25rem 0; }
    .trio article + article { border-left: none; border-top: 1px solid hsl(var(--color-border)); }
    .impact-grid { grid-template-columns: 1fr; }
    .stat-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 520px) {
    .stat-grid { grid-template-columns: 1fr; }
  }
</style>
