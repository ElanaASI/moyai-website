---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL;
const url = (path: string) => `${base.replace(/\/$/, '')}/${path.replace(/^\//, '')}`;

const storyImages = [
  {
    src: url('images/story-short-hair-smile.jpg'),
    alt: 'A lady with short hair and a warm smile facing the camera.',
    w: 931,
    h: 1071,
  },
  {
    src: url('images/story-couple-power-wheelchair.jpg'),
    alt: 'A man standing next to his wife who is a power drive wheelchair user.',
    w: 886,
    h: 1133,
  },
  {
    src: url('images/story-tina-races.jpg'),
    alt: 'Tina, a Moyai user, sitting on a white folding chair dressed up for the races.',
    w: 768,
    h: 1024,
  },
  {
    src: url('images/story-flowers-wheelchair.jpg'),
    alt: 'A lady sitting in a wheelchair with a warm smile and a large bunch of flowers on her lap.',
    w: 571,
    h: 1024,
  },
];

const values = [
  { title: 'Clarity', body: 'A profound understanding through insight.' },
  { title: 'Compassion', body: 'Act with care and consideration.' },
  { title: 'Evolution', body: 'Leading through curiosity and learning.' },
  { title: 'Amplifying', body: 'Make the unheard roar.' },
];

const pvm = [
  { label: 'Purpose', body: 'To ensure everyone can live a fulfilling life.' },
  { label: 'Vision', body: 'We see a world that works for all bodies, minds and needs.' },
  { label: 'Mission', body: 'We are the trusted source for accessibility tools, data and action.' },
];
---

<Layout
  title="About Moyai"
  description="Moyai was founded by physiotherapist Elana Fernandes to build a world that works for all bodies, minds and needs — grounded in empathy and shaped by lived experience."
>
  <!-- Intro -->
  <section class="section about-hero">
    <div class="container story-grid">
      <div class="story-copy">
        <h1>How the story began</h1>
        <p class="lead">
          Accessible rooms exist in hotels across Australia. But when guests with accessibility
          and sensory needs call to ask about door clearance widths, grab rail placement or
          whether check-in can be completed without verbal communication, too often the answer
          is a guess.
        </p>
        <p class="lead">
          Moyai was founded by physiotherapist Elana Fernandes and exercise physiologist Jess
          Combe. Inspired by Elana's brother and the clients both founders have supported
          throughout their careers, they saw the same problem repeatedly: hotels had accessible
          rooms but no verified, reliable information to give guests the confidence to book.
        </p>
        <p class="lead">
          Collecting information is not enough. Without verification, data becomes inconsistent
          across platforms, goes out of date and no longer reflects the current picture of the
          property. Guests are misled. Trust is lost. Moyai verifies what is actually there and
          keeps that information accurate and consistent across every channel, so when a guest
          calls, your team has an answer they can stand behind.
        </p>
        <p class="lead">
          At the heart of everything Moyai does is the bold vision to create a world that works
          for all bodies, minds and needs.
        </p>
      </div>
      <div class="story-media">
        {storyImages.map((img) => (
          <img src={img.src} alt={img.alt} width={img.w} height={img.h} loading="lazy" />
        ))}
      </div>
    </div>
  </section>

  <!-- Section divider (full page width) -->
  <hr class="section-divider" />

  <!-- Triple Impact Model -->
  <section class="section impact-section">
    <div class="container">
      <div class="impact-grid">
        <article class="card impact-lead">
          <h2>Verified information</h2>
          <p class="text-muted">
            Moyai verifies your property's accessibility information so your team has accurate,
            reliable data to share with guests. What you communicate on your website, your OTA
            listings, and over the phone stays consistent and reflects what your property
            actually offers.
          </p>
        </article>
        <article class="card">
          <h3>Data for purpose</h3>
          <p class="text-muted">
            Moyai shows you where your accessibility already works so you can promote it with
            confidence, and identifies the simple adjustments that could unlock more bookings.
          </p>
        </article>
        <article class="card">
          <h3>Inclusive employment pathways</h3>
          <p class="text-muted">
            Moyai is built to create real employment opportunities for people living with
            disabilities, bringing lived experience into the work of making travel more
            inclusive for everyone.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- Purpose / Vision / Mission -->
  <section class="section">
    <div class="container">
      <h2 class="sr-only">Purpose, vision and mission</h2>
      <div class="pvm-grid">
        {pvm.map((item) => (
          <article class="pvm">
            <h3>{item.label}</h3>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Purpose statement banner -->
  <section class="purpose-section">
    <div class="container">
      <h2 class="section-title">Purpose statement</h2>
      <p class="reinvest">
        More than 50% of Moyai's profits are reinvested into creating meaningful employment
        pathways for people living with disabilities, enhancing our accessibility monitoring
        tools and building more inclusive communities.
      </p>
      <p class="reinvest">
        By continually improving our platform and tools, we empower businesses with the
        insights they need to make smarter, targeted accessibility investments, creating
        spaces where everyone can confidently participate and belong.
      </p>
    </div>
  </section>

  <!-- Values -->
  <section class="section values-section">
    <div class="container">
      <h2 class="section-title">Moyai company values</h2>
      <ul class="values-list">
        {values.map((v) => (
          <li class="value-item">
            <h3>{v.title}</h3>
            <p class="text-muted">{v.body}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>
</Layout>

<style>
  .narrow { max-width: 64ch; }
  .about-hero { background: hsl(var(--color-secondary) / 0.5); }
  .lead { font-size: 1.2rem; color: #000; }

  /* Story intro: copy beside a grid of photos */
  .story-grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: clamp(2rem, 4vw, 3.5rem);
    align-items: center;
  }
  .story-copy { max-width: 60ch; }
  .story-media {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .story-media img {
    display: block;
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    object-position: center top;
    border-radius: var(--radius);
    box-shadow: 0 12px 30px hsl(var(--color-foreground) / 0.12);
    filter: grayscale(1);
  }


  /* Thin brand-pink section divider (replaces the old commitment banner) */
  .section-divider {
    border: 0;
    border-top: 2px solid #ff7bac; /* official Moyai brand pink */
    margin: 0;
  }

  /* Triple Impact Model */
  .impact-section { background: hsl(var(--color-secondary) / 0.5); }
  .impact-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .impact-grid .card { text-align: center; }
  .impact-lead h2 {
    font-size: 1.375rem;
    color: hsl(var(--color-foreground));
    margin: 0 0 0.6rem;
  }

  .pvm-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .pvm {
    border-left: 4px solid hsl(var(--color-primary));
    padding-left: 1.25rem;
  }
  .purpose-section {
    border-top: 2px solid hsl(var(--color-primary));
    border-bottom: 2px solid hsl(var(--color-primary));
    padding-block: clamp(3rem, 6vw, 4.5rem);
  }
  .reinvest {
    max-width: 70ch;
    margin: 0 auto;
    text-align: center;
    font-size: 1.1rem;
  }
  .reinvest + .reinvest { margin-top: 1.25rem; }

  .values-section { background: hsl(var(--color-secondary) / 0.5); }
  .values-list {
    list-style: none;
    margin: 2rem auto 0;
    padding: 0;
    max-width: 52ch;
    text-align: center;
  }
  .value-item + .value-item { margin-top: 2rem; }
  .value-item h3 { margin-bottom: 0.4rem; }
  .card {
    background: #fff;
    border: 1px solid hsl(var(--color-border));
    border-radius: var(--radius);
    padding: 1.5rem;
  }

  @media (max-width: 880px) {
    .story-grid { grid-template-columns: 1fr; }
    .story-copy { max-width: none; }
    .pvm-grid { grid-template-columns: 1fr; }
    .impact-grid { grid-template-columns: 1fr; }
  }
</style>
