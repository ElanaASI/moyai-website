---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Moyai: Accessibility that grows your business',
  description = 'Moyai verifies venue accessibility in person, so your reservations team can answer confidently and guests can book with certainty. Built by allied health professionals.',
} = Astro.props;

const base = import.meta.env.BASE_URL; // e.g. "/moyai-website"
const url = (path: string) => `${base.replace(/\/$/, '')}/${path.replace(/^\//, '')}`;

const navLinks = [
  { label: 'Home', href: url('') },
  { label: 'About', href: url('about') },
];
const currentYear = 2026;
---

<!doctype html>
<html lang="en-AU">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={url('favicon.svg')} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#f17aa9" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&family=Heebo:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>

    <header class="site-header">
      <div class="container header-inner">
        <a class="brand" href={url('')} aria-label="Moyai home">
          <img src={url('logos/moyai-horizontal.svg')} alt="Moyai" width="150" height="44" />
        </a>
        <nav class="site-nav" aria-label="Primary">
          {navLinks.map((link) => (
            <a href={link.href}>{link.label}</a>
          ))}
          <a class="btn btn-primary nav-cta" href="mailto:hello@moyai.com.au?subject=Let%27s%20talk">Let's talk</a>
        </nav>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-grid">
        <div class="footer-brand">
          <img src={url('logos/moyai-horizontal.svg')} alt="" width="170" height="50" />
          <p class="text-muted footer-acknowledgement">
            Moyai was created on the Sunshine Coast, home of the Kabi Kabi and Jinibara
            peoples, the Traditional Custodians of this land; we pay our respects to Elders
            past and present.
          </p>
        </div>

        <div class="footer-col">
          <h3>Contact</h3>
          <ul>
            <li><a href="mailto:hello@moyai.com.au">hello@moyai.com.au</a></li>
          </ul>
        </div>

        <div class="footer-col">
          <h3>Follow us</h3>
          <ul class="social-list">
            <li>
              <a href="https://instagram.com/moyai_ai" target="_blank" rel="noopener">
                <svg class="social-icon" viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
                  <path d="M12 2c2.717 0 3.056.01 4.122.06 1.065.05 1.79.217 2.428.465.66.254 1.216.598 1.772 1.153a4.9 4.9 0 0 1 1.153 1.772c.247.637.415 1.363.465 2.428.047 1.066.06 1.405.06 4.122 0 2.717-.01 3.056-.06 4.122-.05 1.065-.218 1.79-.465 2.428a4.9 4.9 0 0 1-1.153 1.772 4.9 4.9 0 0 1-1.772 1.153c-.637.247-1.363.415-2.428.465-1.066.047-1.405.06-4.122.06-2.717 0-3.056-.01-4.122-.06-1.065-.05-1.79-.218-2.428-.465a4.9 4.9 0 0 1-1.772-1.153 4.9 4.9 0 0 1-1.153-1.772c-.248-.637-.415-1.363-.465-2.428C2.013 15.056 2 14.717 2 12c0-2.717.01-3.056.06-4.122.05-1.066.217-1.79.465-2.428a4.9 4.9 0 0 1 1.153-1.772A4.9 4.9 0 0 1 5.45 2.525c.638-.248 1.363-.415 2.428-.465C8.944 2.013 9.283 2 12 2zm0 1.802c-2.67 0-2.987.01-4.04.059-.976.045-1.505.207-1.858.344-.466.182-.8.398-1.15.748-.35.35-.566.684-.748 1.15-.137.353-.3.882-.344 1.857-.048 1.055-.058 1.37-.058 4.04 0 2.67.01 2.986.058 4.04.045.976.207 1.505.344 1.858.182.466.399.8.748 1.15.35.35.684.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.059 4.041.059 2.67 0 2.987-.01 4.04-.059.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.684.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041 0-2.67-.01-2.986-.058-4.04-.045-.976-.207-1.505-.344-1.858a3.1 3.1 0 0 0-.748-1.15 3.1 3.1 0 0 0-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.055-.048-1.371-.059-4.041-.059zm0 3.064a5.135 5.135 0 1 1 0 10.27 5.135 5.135 0 0 1 0-10.27zm0 8.468a3.333 3.333 0 1 0 0-6.666 3.333 3.333 0 0 0 0 6.666zm6.538-8.671a1.2 1.2 0 1 1-2.4 0 1.2 1.2 0 0 1 2.4 0z"/>
                </svg>
                <span>Instagram</span><span class="sr-only"> (opens in a new tab)</span>
              </a>
            </li>
            <li>
              <a href="https://linkedin.com/company/moyai" target="_blank" rel="noopener">
                <svg class="social-icon" viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
                  <path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.22.79 24 1.77 24h20.45c.98 0 1.78-.78 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z"/>
                </svg>
                <span>LinkedIn</span><span class="sr-only"> (opens in a new tab)</span>
              </a>
            </li>
          </ul>
        </div>
      </div>

      <div class="container footer-bottom">
        <p class="text-muted">Copyright © {currentYear} Moyai Pty Ltd. ABN 81 678 413 664</p>
        <a href={url('privacy')}>Privacy Policy</a>
      </div>
    </footer>

    <style>
      .site-header {
        position: sticky;
        top: 0;
        z-index: 50;
        background: hsl(var(--color-background) / 0.9);
        backdrop-filter: saturate(180%) blur(10px);
        border-bottom: 1px solid hsl(var(--color-border));
      }
      .header-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        min-height: 96px;
      }
      .brand img { height: 76px; width: auto; }
      .site-nav {
        display: flex;
        align-items: center;
        gap: 1.75rem;
      }
      .site-nav > a:not(.btn) {
        font-family: var(--font-heading);
        font-weight: 500;
        color: hsl(var(--color-foreground));
      }
      .site-nav > a:not(.btn):hover { color: hsl(var(--color-primary-foreground)); text-decoration: underline; text-underline-offset: 4px; }
      .nav-cta { padding: 0.55rem 1.25rem; }

      .site-footer {
        background: hsl(var(--color-secondary));
        margin-top: 2rem;
        padding-block: 3.5rem 1.5rem;
        border-top: 1px solid hsl(var(--color-border));
      }
      .footer-grid {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr;
        gap: 2.5rem;
      }
      .footer-brand img { height: 46px; width: auto; margin-bottom: 1rem; }
      .footer-acknowledgement { max-width: 42ch; font-size: 0.95rem; }
      .footer-col h3 { font-size: 1rem; margin-bottom: 0.85rem; }
      .footer-col ul { list-style: none; margin: 0; padding: 0; display: grid; gap: 0.5rem; }
      .footer-col a {
        color: hsl(var(--color-secondary-foreground));
        display: inline-flex;
        align-items: center;
        min-height: 24px;
      }
      .footer-col a:hover { color: hsl(var(--color-primary-foreground)); text-decoration: underline; }
      .social-list a {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
      }
      .social-icon {
        flex-shrink: 0;
        color: hsl(var(--color-primary));
        transition: color 0.15s ease;
      }
      .social-list a:hover .social-icon { color: hsl(var(--color-primary-foreground)); }
      .footer-bottom {
        margin-top: 2.5rem;
        padding-top: 1.5rem;
        border-top: 1px solid hsl(var(--color-border));
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 0.5rem 1.5rem;
      }
      .footer-bottom p { margin: 0; font-size: 0.9rem; }
      .footer-bottom a {
        font-size: 0.9rem;
        color: hsl(var(--color-secondary-foreground));
        display: inline-flex;
        align-items: center;
        min-height: 24px;
      }
      .footer-bottom a:hover { color: hsl(var(--color-primary-foreground)); text-decoration: underline; }

      @media (max-width: 760px) {
        .site-nav { gap: 1rem; }
        .site-nav > a:not(.btn) { display: none; }
        .footer-grid { grid-template-columns: 1fr; gap: 2rem; }
      }
    </style>
  </body>
</html>
